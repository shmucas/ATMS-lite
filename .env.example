# Copy to .env and fill in real values. Never commit .env.
ATMS_CONTROLLER_HOST=10.42.0.2
ATMS_CONTROLLER_SNMP_PORT=161
# The MaxTime agent is SNMP v1 only. v2c requests are silently ignored.
ATMS_SNMP_VERSION=1
ATMS_SNMP_READ_COMMUNITY=public
ATMS_SNMP_WRITE_COMMUNITY=fill-me-in
ATMS_POLL_HZ=5
# Token guarding the control (write) endpoints. Leave empty on an isolated
# bench; set it (and VITE_CONTROL_TOKEN in the frontend build) before any
# deployment reachable by others.
ATMS_CONTROL_TOKEN=
# Seconds before an armed intersection auto-disarms and clears its calls.
ATMS_ARM_TIMEOUT_S=300
