# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
dist/
.vite/
*.tsbuildinfo

# Environment and secrets
.env
.env.*
!.env.example
# Per-intersection SNMP community overrides (public repo, never commit)
backend/communities.local.json

# Controller database exports stay local (public repo)
docs/backups/*
!docs/backups/.gitkeep
*.pdf

# Vendor reference dumps dropped into the knowledgebase (JSON exports, etc.).
# The tracked plan docs (*.md) and out.txt stay in the repo.
docs/knowledgebase/*.json

# Raw SNMP walk dumps: multi-MB and mostly vendor objects. Regenerate with
# tools/discover.py. The committed docs/oid-inventory.md summary and
# docs/ntcip-oids.md reference carry what we actually use.
docs/oid-inventory*.json

# Editor and local tooling
.DS_Store
*.code-workspace
.claude/
*.log
